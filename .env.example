# =============================================
#  블로그 자동 발행 시스템 환경변수 설정
#  .env.example 을 복사해서 .env 로 만드세요
# =============================================

# 대시보드 접근 비밀번호
DASHBOARD_PASSWORD=your_password_here

# 서버 포트
PORT=3000

# ── 네이버 블로그 ──────────────────────────
NAVER_ID=your_naver_id
NAVER_PW=your_naver_password
NAVER_BLOG_ID=your_naver_blog_id   # 예: myblog (blog.naver.com/myblog)

# ── 티스토리 ──────────────────────────────
TISTORY_CLIENT_ID=your_tistory_app_key
TISTORY_CLIENT_SECRET=your_tistory_secret
TISTORY_ACCESS_TOKEN=                  # OAuth 후 자동 채워짐
TISTORY_BLOG_NAME=your_blog_name       # 예: myblog (myblog.tistory.com)

# ── 구글 블로거 (Blogspot) ────────────────
BLOGGER_CLIENT_ID=your_google_client_id
BLOGGER_CLIENT_SECRET=your_google_client_secret
BLOGGER_REFRESH_TOKEN=                 # OAuth 후 자동 채워짐
BLOGGER_BLOG_ID=                       # 예: 1234567890

# ── 텔레그램 알림 ─────────────────────────
TELEGRAM_BOT_TOKEN=          # @BotFather 에서 발급
TELEGRAM_CHAT_ID=            # @userinfobot 에서 확인

# ── Cloudinary (이미지 호스팅, 선택사항) ──
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
