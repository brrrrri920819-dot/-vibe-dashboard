{
  "name": "vibe-blog-publisher",
  "version": "1.0.0",
  "description": "Multi-platform blog auto-publisher (Naver, Tistory, Blogspot)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "install-browsers": "npx playwright install chromium --with-deps",
    "postinstall": "npx playwright install chromium --with-deps || echo '[Playwright] 브라우저 설치 실패 (무시 가능)'"
  },
  "dependencies": {
    "express": "^4.18.2",
    "playwright": "^1.44.0",
    "node-cron": "^3.0.3",
    "multer": "^1.4.5-lts.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "axios": "^1.7.2",
    "form-data": "^4.0.0",
    "cheerio": "^1.0.0-rc.12"
  }
}
